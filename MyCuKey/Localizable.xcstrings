          }
        }
      }
    },
    "Tap and hold the 🌐 Globe button located at the bottom left of your standard Apple Keyboard." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Halte die 🌐-Globus-Taste unten links auf der normalen Apple-Tastatur gedrückt."
          }
        }
      }
    },
    "Tap on MyCuKey again and toggle \"Allow Full Access\" to enable all features." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tippe erneut auf MyCuKey und aktiviere „Vollen Zugriff erlauben“, um alle Funktionen zu nutzen."
          }
        }
      }
    },
    "Words you add here, or words the keyboard learns after repeated correction reverts, will stop being autocorrected." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wörter, die du hier hinzufügst oder die die Tastatur nach wiederholtem Rückgängigmachen lernt, werden künftig nicht mehr automatisch korrigiert."
          }
        }
      }
    }
